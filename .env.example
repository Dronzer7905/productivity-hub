# ── COMMANDFLOW CONFIGURATION ───────────────────────────
# Copy this file to .env and fill in your details

# ── APP SETTINGS ───────────────────────────────────────
# Set to 'development' for local work, 'production' for server
FLASK_ENV=production
DEBUG=False

# Server listening configuration
HOST=0.0.0.0
PORT=5000

# Generate a strong secret key using: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your-super-secret-key-here

# ── DATABASE ──────────────────────────────────────────
# Leave blank to use local SQLite (database.db)
# Example for Postgres: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ── SECURITY ──────────────────────────────────────────
# Set to True if using HTTPS/SSL (recommended for production)
SESSION_COOKIE_SECURE=False
