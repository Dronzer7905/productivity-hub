# Environment Variables for Productivity Hub
# Copy this to .env and fill in your values
# NEVER commit the actual .env file to Git!

# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py

# Security - Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-long-random-secret-key-here-change-this

# Database
DATABASE_URL=sqlite:////var/www/productivity-hub/productivity.db

# Application Domain
APP_DOMAIN=commandflow.devtailored.com

# Optional: Email Configuration (if you add email features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Optional: Debug Mode (set to False in production)
DEBUG=False

# Optional: Admin Settings
# ADMIN_EMAIL=admin@example.com
